{
  "name": "@anmollabs/dynamically-client",
  "version": "0.0.1",
  "description": "Framework-agnostic TypeScript SDK for the Dynamically headless content API. Includes a Next.js helper.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "cms",
    "headless-cms",
    "content",
    "dynamically",
    "next.js",
    "sdk"
  ],
  "homepage": "https://github.com/Anmol1377/dynamically#readme",
  "bugs": {
    "url": "https://github.com/Anmol1377/dynamically/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Anmol1377/dynamically.git",
    "directory": "packages/client"
  },
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./next": {
      "types": "./src/next.ts",
      "default": "./src/next.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@types/node": "^20.16.13",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      },
      "./next": {
        "types": "./dist/next.d.ts",
        "import": "./dist/next.js",
        "require": "./dist/next.cjs"
      }
    }
  }
}
