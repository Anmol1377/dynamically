**/node_modules
**/.next
**/dist
**/.turbo

# Local data — never ship in the image (be explicit, not glob, so we don't
# accidentally exclude source dirs named uploads/data)
apps/web/data
apps/web/uploads
**/*.db
**/*.db-journal
**/*.db-wal
**/*.db-shm

# Test / dev artefacts
**/coverage
**/.env
**/.env.local
**/.env.*.local
*.log
.DS_Store
.git
.github
.vscode
.idea
**/*.tsbuildinfo
**/next-env.d.ts

# Examples — they're not part of the runtime image
examples

# Scaffolder template (regenerated; not needed in the runtime image)
packages/create-dynamically-app/template
packages/client/dist
